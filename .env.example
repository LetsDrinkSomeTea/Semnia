# ============================================================
# Semnia — Environment Configuration
# Copy to .env and adjust values as needed.
# All variables are optional — built-in defaults apply.
# ============================================================


# ── Network ──────────────────────────────────────────────────
# Set to false to disable SSL certificate verification for model downloads
# (e.g. behind a corporate proxy that intercepts TLS). Default: true.
# SSL_VERIFY=true


# ── Timezone ─────────────────────────────────────────────────
# IANA timezone name (affects log timestamps and locale-aware formatting).
# Default: Europe/Berlin (set in the backend, not here).
# TZ=Europe/Berlin


# ── Paths ────────────────────────────────────────────────────
# Where the SQLite database is stored (inside the container).
# DB_PATH=/data/wissensdatenbank.sqlite

# Where uploaded files are stored.
# UPLOAD_PATH=/data/uploads


# ── Embedding Model ──────────────────────────────────────────
# HuggingFace model ID used for semantic search (via fastembed).
# The embedding dimension is auto-detected at startup — you do not need
# to set EMBEDDING_DIM unless you need to force a specific value.
#
# Changing the model triggers automatic table recreation and a full
# re-embedding of all entries on the next startup.
#
# Supported multilingual models (fastembed):
#
#   sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2  [384d, ~120 MB]
#     Fast and compact, ~50 languages. Good when resources are tight.
#
#   sentence-transformers/paraphrase-multilingual-mpnet-base-v2   [768d, ~280 MB]
#     Default. Good balance of quality and speed. ~50 languages.
#     384-token input limit (~1500 chars). The default CHUNK_SIZE=800 stays
#     well within this, but raising CHUNK_SIZE above ~1500 risks silent
#     tail truncation of chunks.
#
#   intfloat/multilingual-e5-large                                [1024d, ~560 MB]
#     Best multilingual quality available. ~100 languages, 2024 model.
#     Needs ~1 GB RAM and slower indexing. Best overall if resources allow.
#
#   jinaai/jina-embeddings-v2-base-de                             [768d, ~280 MB]
#     Optimised for German + English. Supports up to 8192 tokens per chunk —
#     useful if you store very long documents without chunking.
#
# English-only (faster/smaller, no German support):
#   BAAI/bge-small-en-v1.5   [384d, ~33 MB]
#   BAAI/bge-base-en-v1.5    [768d, ~109 MB]
#   BAAI/bge-large-en-v1.5   [1024d, ~335 MB]
#
# Note: not all HuggingFace model IDs work — only models listed above are
# bundled in fastembed. An unsupported name causes a startup error with the
# full list of valid options.
#
# EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2

# Override the auto-detected embedding dimension. Only needed if you use a
# model not listed above and auto-detection gives wrong results.
# Warning: setting this to a value that doesn't match the model's actual output
# dimension will cause every embedding insert to fail silently.
# EMBEDDING_DIM=384

# fastembed model cache directory (inside the container).
# FASTEMBED_CACHE_PATH=/model-cache


# ── Search ───────────────────────────────────────────────────
# Minimum relevance score for a result to be shown (0.0–1.0).
# Score is relative: 0% = noise floor (average candidate), 100% = perfect match.
# Lower = more results but potentially noisier.
# SEARCH_THRESHOLD=0.3

# Score threshold above which two entries are flagged as duplicates.
# DUPE_THRESHOLD=0.9

# Maximum number of results returned per search.
# TOP_K=15

# Maximum characters per chunk when splitting documents and Q&A answers.
# Smaller chunks produce more specific embeddings and better retrieval precision.
# Larger chunks provide more context per result but dilute semantic signal.
# Note: changing this triggers a re-embedding of all entries on the next startup.
# CHUNK_SIZE=200

# Overlap between consecutive chunks in characters.
# Prevents relevant content from being split across chunk boundaries.
# CHUNK_OVERLAP=40


# ── Branding ─────────────────────────────────────────────────
# Display name shown in the topbar and browser tab.
# The last 3 characters are rendered in the accent color.
# APP_NAME=Semnia

# Primary accent color (buttons, links, active states). CSS hex value.
# ACCENT_COLOR=#9933ee

# CSS font-family stack applied to body and headings.
# Leave unset to use the default (Inter / system-ui).
# FONT_STACK=Inter, system-ui, sans-serif

# Inject custom CSS into the frontend as a <style> tag.
# Use CUSTOM_CSS for an inline string or CUSTOM_CSS_FILE for a mounted file.
# CUSTOM_CSS=:root { --radius: 8px; } .pb-topbar { background: #1a1a2e; }
# CUSTOM_CSS_FILE=/custom/custom.css

# Path to a mounted logo file (PNG, SVG, JPEG). Base64-encoded at startup.
# BRANDING_LOGO_FILE=/custom/logo.svg


# ── LLM (optional AI summaries) ──────────────────────────────
# Supports any OpenAI-compatible API (OpenAI, Ollama, LM Studio, vLLM, …).
# The feature is activated when LLM_API_KEY is set or LLM_URL differs from default.
#
# Default points to the bundled Ollama container (docker compose --profile llm).
# No env vars needed for the Ollama default — just start with --profile llm.
#
# To use a different Ollama model:
#   LLM_MODEL=llama3.2:3b
#
# OpenAI (or any other OpenAI-compatible API):
#   LLM_URL=https://api.openai.com/v1
#   LLM_MODEL=gpt-4o-mini
#   LLM_API_KEY=sk-...
#
# LM Studio / vLLM:
#   LLM_URL=http://localhost:1234/v1
#   LLM_MODEL=your-model-name
#
# LLM_URL=http://ollama:11434/v1
# LLM_MODEL=llama3.2:1b
# LLM_API_KEY=
#
# AGENT_MAX_TURNS=30
#
# Agent tracing (sends traces to the OpenAI dashboard for debugging):
# If LLM_URL points to openai.com and LLM_API_KEY is set, tracing is
# enabled automatically using LLM_API_KEY. Set LLM_TRACES_OPENAI_KEY
# explicitly to use a different key, or to enable tracing when using
# a non-OpenAI LLM endpoint.
# LLM_TRACES_OPENAI_KEY=sk-...


# ── Advanced ─────────────────────────────────────────────────
# Meilisearch connection (defaults to the bundled meilisearch container in docker compose).
# MEILISEARCH_URL=http://meilisearch:7700
# MEILISEARCH_KEY=semnia_local_dev_key

# Comma-separated list of allowed CORS origins.
# Default covers the standard dev (5173) and prod (3000) ports.
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Enable demo mode: blocks destructive operations (delete, reset).
# DEMO=false
