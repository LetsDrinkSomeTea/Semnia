# ============================================================
# Semnia — Environment Configuration
# Copy to .env and adjust values as needed.
# All variables are optional — built-in defaults apply.
# ============================================================


# ── Paths ────────────────────────────────────────────────────
# Where the SQLite database is stored (inside the container).
DB_PATH=/data/wissensdatenbank.sqlite

# Where uploaded files are stored.
UPLOAD_PATH=/data/uploads


# ── Embedding Model ──────────────────────────────────────────
# HuggingFace model ID used for semantic search (via fastembed).
# The embedding dimension is auto-detected at startup — you do not need
# to set EMBEDDING_DIM unless you need to force a specific value.
#
# Changing the model triggers automatic table recreation and a full
# re-embedding of all entries on the next startup.
#
# Supported multilingual models (fastembed):
#
#   sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2  [384d, ~120 MB]
#     Default. Fast, compact, ~50 languages. Good general-purpose choice.
#
#   sentence-transformers/paraphrase-multilingual-mpnet-base-v2   [768d, ~280 MB]
#     Better quality than the default, especially for longer texts. ~2× slower.
#     Only 384 input tokens — chunks longer than that are silently truncated.
#
#   intfloat/multilingual-e5-large                                [1024d, ~560 MB]
#     Best multilingual quality available. ~100 languages, 2024 model.
#     Needs ~1 GB RAM and slower indexing. Best overall if resources allow.
#
#   jinaai/jina-embeddings-v2-base-de                             [768d, ~280 MB]
#     Optimised for German + English. Supports up to 8192 tokens per chunk —
#     useful if you store very long documents without chunking.
#
# English-only (faster/smaller, no German support):
#   BAAI/bge-small-en-v1.5   [384d, ~33 MB]
#   BAAI/bge-base-en-v1.5    [768d, ~109 MB]
#   BAAI/bge-large-en-v1.5   [1024d, ~335 MB]
#
# Note: not all HuggingFace model IDs work — only models listed above are
# bundled in fastembed. An unsupported name causes a startup error with the
# full list of valid options.
#
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Override the auto-detected embedding dimension. Only needed if you use a
# model not listed above and auto-detection gives wrong results.
# EMBEDDING_DIM=384

# fastembed model cache directory (inside the container).
FASTEMBED_CACHE_PATH=/model-cache


# ── Search ───────────────────────────────────────────────────
# Minimum hybrid score for a result to be shown (0.0–1.0).
# Lower = more results but potentially noisier.
SEARCH_THRESHOLD=0.2

# Score threshold above which two entries are flagged as duplicates.
DUPE_THRESHOLD=0.92

# Maximum number of results returned per search.
TOP_K=15

# Weight of semantic (vector) vs. full-text (BM25) search.
# 1.0 = pure semantic  |  0.0 = pure BM25  |  0.7 = recommended default.
# Lower values help BM25 matches (exact keywords) compete with semantic ones.
HYBRID_ALPHA=0.7

# Maximum characters per chunk when splitting documents and Q&A answers.
# Smaller chunks = more precise retrieval. Larger = more context per result.
CHUNK_SIZE=800

# Overlap between consecutive chunks in characters.
# Prevents relevant content from being split across chunk boundaries.
CHUNK_OVERLAP=150


# ── Branding ─────────────────────────────────────────────────
# Display name shown in the topbar and browser tab.
# The last 3 characters are rendered in the accent color.
# APP_NAME=Semnia

# Primary accent color (buttons, links, active states). CSS hex value.
# ACCENT_COLOR=#cc0033

# CSS font-family stack applied to body and headings.
# Leave unset to use the default (Inter / system-ui).
# FONT_STACK=Inter, system-ui, sans-serif

# Inject custom CSS into the frontend as a <style> tag.
# Use CUSTOM_CSS for an inline string or CUSTOM_CSS_FILE for a mounted file.
# CUSTOM_CSS=:root { --radius: 8px; } .pb-topbar { background: #1a1a2e; }
# CUSTOM_CSS_FILE=/custom/custom.css

# Path to a mounted logo file (PNG, SVG, JPEG). Base64-encoded at startup.
# BRANDING_LOGO_FILE=/custom/logo.svg


# ── Ollama (optional LLM summaries) ──────────────────────────
# URL of the Ollama API. Remove or leave empty to disable AI summaries.
# OLLAMA_URL=http://ollama:11434

# Ollama model for AI summaries. Must be pulled on the Ollama server first.
# Small models (3b–7b) are usually sufficient for summarisation.
# OLLAMA_MODEL=llama3.2:3b
